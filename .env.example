# Anthropic API kaliti — FAQAT server tomonida ishlatiladi (api/chat.js).
# VITE_ prefiksi YO'Q, shuning uchun brauzerga chiqmaydi.
# Production'da bu kalit Vercel'da "Environment Variables" ichida saqlanadi.
# Lokal sinov uchun (vercel dev) shu nom bilan .env ga qo'ying:
ANTHROPIC_KEY=sk-ant-bu-yerga-yangi-keyingizni-qoying

# Foydalanuvchi akkauntlari (api/auth.js) uchun sessiya tokenini imzolovchi maxfiy kalit.
# Uzun, tasodifiy satr bo'lsin (masalan: openssl rand -hex 32).
# Agar bu bo'lmasa yoki Redis ulanmagan bo'lsa — sayt "mehmon" rejimida ishlaydi.
AUTH_SECRET=bu-yerga-uzun-tasodifiy-satr-qoying

# Admin paneli paroli (api/admin.js) — o'qituvchi uchun.
ADMIN_PASSWORD=admin-parolini-qoying

# Redis ulanishi (Vercel "Redis" integratsiyasi avtomatik beradi: REDIS_URL yoki KV_URL).
# Akkauntlar va statistika shu yerda saqlanadi.
# REDIS_URL=redis://...
